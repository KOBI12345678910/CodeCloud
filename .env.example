# Platform foundation environment variables.
# Copy to `.env` for local dev. NEVER commit real secrets.

# ── Runtime ───────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
PORT=8080
METRICS_PORT=9100

# ── Auth / crypto ─────────────────────────────────────────────────────
# Required: 32+ char random strings. Generate with: openssl rand -hex 32
SESSION_SECRET=replace-me-with-openssl-rand-hex-32-min-32-chars-required
CSRF_SECRET=replace-me-with-openssl-rand-hex-32-min-32-chars-required
SECRETS_ENCRYPTION_KEY=replace-me-with-openssl-rand-hex-32-min-32-chars

# ── Feature flags ─────────────────────────────────────────────────────
DSAR_ENABLED=false

# ── Datastores (defaults match docker-compose.yml) ────────────────────
DATABASE_URL=postgres://platform:platform@localhost:5432/platform
REDIS_URL=redis://localhost:6379
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=dev-master-key
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=platform
S3_SECRET_KEY=platform-dev
S3_BUCKET=platform-dev

# ── Observability (all optional — telemetry no-ops when unset) ────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
SENTRY_DSN=
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
