{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "Platform Overview",
  "tags": ["platform", "foundation"],
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "HTTP request rate (per service)",
      "targets": [
        {
          "expr": "sum by (service) (rate(http_requests_total[5m]))",
          "legendFormat": "{{service}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "graph",
      "title": "p95 request latency",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, service) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{service}} p95"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "id": 3,
      "type": "graph",
      "title": "Worker queue depth (BullMQ)",
      "targets": [
        { "expr": "sum by (queue) (bullmq_jobs_waiting)", "legendFormat": "{{queue}}" }
      ],
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 }
    }
  ]
}
